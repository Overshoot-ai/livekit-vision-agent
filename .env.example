# LiveKit: inferred automatically by `lk app create`
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Overshoot: get a key at https://platform.overshoot.ai
OVERSHOOT_API_KEY=

# Optional overrides
# Vision-language model served by Overshoot (any model at https://models.overshoot.ai)
OVERSHOOT_MODEL=google/gemma-4-26B-A4B-it
# How often the agent analyzes the video, in frames per second
VISION_FPS=2
# What the agent looks for in the video (plain English)
VISION_PROMPT=Describe what is happening in the video.
